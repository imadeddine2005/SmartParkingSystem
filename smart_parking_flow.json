    {
        "id": "ui_template_svg",
        "type": "ui_template",
        "z": "tab_smart_parking",
        "group": "ui_group_dashboard",
        "name": "SVG Interactive Parking",
        "order": 1,
        "width": "18",
        "height": "10",
        "format": "<script>\n    (function(scope) {\n        // Réception en temps réel des messages MQTT via ui_template\n        scope.$watch('msg', function(msg) {\n            if (msg && msg.topic && msg.payload) {\n                var parts = msg.topic.split('/');\n                if (parts[1] && parts[1].startsWith('P')) {\n                    var slotId = parts[1]; // P1, P2... P10\n                    var state = msg.payload.state;\n                    \n                    // Mise à jour de la couleur via le DOM SVG\n                    var el = document.getElementById(slotId);\n                    if (el) {\n                        if(state === 'free') {\n                            el.style.fill = '#2ecc71'; // Vert libéré\n                        } else {\n                            el.style.fill = '#e74c3c'; // Rouge occupé\n                        }\n                    }\n                }\n            }\n        });\n    })(scope);\n</script>\n<style>\n    .svg-container {\n        width: 100%;\n        height: 100%;\n        background: linear-gradient(135deg, #1f2a36 0%, #2c3e50 100%);\n        border-radius: 12px;\n        display: flex;\n        justify-content: center;\n        align-items: center;\n        box-shadow: inset 0px 0px 20px rgba(0,0,0,0.5);\n    }\n    .parking-slot { \n        fill: #2ecc71; \n        stroke: #95a5a6; \n        stroke-width: 3; \n        rx: 10;\n        transition: fill 0.5s ease-in-out; \n    }\n    .parking-text {\n        fill: #ffffff;\n        font-family: 'Inter', 'Segoe UI', sans-serif;\n        font-weight: 700;\n        font-size: 26px;\n        pointer-events: none;\n    }\n    .parking-road { \n        fill: #34495e; \n        rx: 5; \n    }\n    .line-dashed { \n        fill: none; \n        stroke: #ecf0f1; \n        stroke-width: 6; \n        stroke-dasharray: 20,20; \n    }\n</style>\n\n<div class=\"svg-container\">\n    <svg width=\"100%\" height=\"100%\" viewBox=\"0 0 900 450\" preserveAspectRatio=\"xMidYMid meet\">\n        <!-- Arrière plan route -->\n        <rect class=\"parking-road\" x=\"30\" y=\"180\" width=\"840\" height=\"90\" />\n        <line x1=\"50\" y1=\"225\" x2=\"850\" y2=\"225\" class=\"line-dashed\" />\n\n        <!-- Ligne du haut (P1 à P5) -->\n        <rect id=\"P1\" class=\"parking-slot\" x=\"60\" y=\"30\" width=\"120\" height=\"150\" />\n        <text x=\"120\" y=\"110\" text-anchor=\"middle\" class=\"parking-text\">P1</text>\n        \n        <rect id=\"P2\" class=\"parking-slot\" x=\"220\" y=\"30\" width=\"120\" height=\"150\" />\n        <text x=\"280\" y=\"110\" text-anchor=\"middle\" class=\"parking-text\">P2</text>\n        \n        <rect id=\"P3\" class=\"parking-slot\" x=\"380\" y=\"30\" width=\"120\" height=\"150\" />\n        <text x=\"440\" y=\"110\" text-anchor=\"middle\" class=\"parking-text\">P3</text>\n        \n        <rect id=\"P4\" class=\"parking-slot\" x=\"540\" y=\"30\" width=\"120\" height=\"150\" />\n        <text x=\"600\" y=\"110\" text-anchor=\"middle\" class=\"parking-text\">P4</text>\n        \n        <rect id=\"P5\" class=\"parking-slot\" x=\"700\" y=\"30\" width=\"120\" height=\"150\" />\n        <text x=\"760\" y=\"110\" text-anchor=\"middle\" class=\"parking-text\">P5</text>\n\n        <!-- Ligne du bas (P6 à P10) -->\n        <rect id=\"P6\" class=\"parking-slot\" x=\"60\" y=\"270\" width=\"120\" height=\"150\" />\n        <text x=\"120\" y=\"350\" text-anchor=\"middle\" class=\"parking-text\">P6</text>\n        \n        <rect id=\"P7\" class=\"parking-slot\" x=\"220\" y=\"270\" width=\"120\" height=\"150\" />\n        <text x=\"280\" y=\"350\" text-anchor=\"middle\" class=\"parking-text\">P7</text>\n        \n        <rect id=\"P8\" class=\"parking-slot\" x=\"380\" y=\"270\" width=\"120\" height=\"150\" />\n        <text x=\"440\" y=\"350\" text-anchor=\"middle\" class=\"parking-text\">P8</text>\n        \n        <rect id=\"P9\" class=\"parking-slot\" x=\"540\" y=\"270\" width=\"120\" height=\"150\" />\n        <text x=\"600\" y=\"350\" text-anchor=\"middle\" class=\"parking-text\">P9</text>\n        \n        <rect id=\"P10\" class=\"parking-slot\" x=\"700\" y=\"270\" width=\"120\" height=\"150\" />\n        <text x=\"760\" y=\"350\" text-anchor=\"middle\" class=\"parking-text\">P10</text>\n    </svg>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resizes": true,
        "templateScope": "local",
        "className": "",
        "x": 420,
        "y": 100,
        "wires": [
            []
        ]
