    {
        "id": "function_logs",
        "type": "function",
        "z": "tab_smart_parking",
        "name": "Formatage des Logs",
        "func": "if (msg.topic === 'parking/available') return null;\nvar slotId = msg.topic.split('/')[1];\nvar isFree = msg.payload.state === 'free';\n\n// Génération d'une phrase colorée pour le log\nmsg.payload = (isFree ? '🟢' : '🔴') + ' ' + slotId + (isFree ? ' est maintenant LIBRE' : ' a été OCCUPÉE');\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 420,
        "y": 160,
        "wires": [
            [
                "ui_text_logs"
            ]
        ]
    },
    {
        "id": "ui_text_logs",
